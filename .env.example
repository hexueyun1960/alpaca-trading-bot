ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

ALPACA_SYMBOLS=AAPL,MSFT,NVDA
ALPACA_TIMEFRAME=1Min
ALPACA_BAR_LIMIT=60
ALPACA_MARKET_DATA_LOOKBACK_DAYS=5

ALPACA_MAX_NOTIONAL_PER_ORDER=500
ALPACA_SHORT_SPIKE_NOTIONAL=500
ALPACA_MIN_CASH_RESERVE=1000

ALPACA_DRY_RUN=true
ALPACA_ENABLE_TRADING=false
ALPACA_ALLOW_LIVE_TRADING=false

ALPACA_JOURNAL_PATH=/opt/alpaca-bot/logs/trade_journal.jsonl
ALPACA_MONITOR_INTERVAL_SECONDS=60
