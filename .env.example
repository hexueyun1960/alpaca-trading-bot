ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_ALLOW_LIVE_TRADING=false

# Execution mode: rest, stream, or shadow.
ALPACA_EXECUTION_MODE=rest
ALPACA_INSTANCE_ID=alpaca-vps-01
ALPACA_REQUIRE_LEADER_LOCK=true
ALPACA_LEADER_LOCK_PATH=/opt/alpaca-bot/logs/execution_leader.lock

ALPACA_SYMBOLS=AAPL,MSFT,NVDA
ALPACA_DYNAMIC_UNIVERSE=false
# Dynamic mode first scans all active US equities, applies asset and daily-bar filters,
# sorts by 30-day dollar volume, then applies this cap. 0 means no cap after filters.
ALPACA_UNIVERSE_MAX_SYMBOLS=1000
ALPACA_UNIVERSE_REFRESH_INTERVAL_SECONDS=3600
ALPACA_UNIVERSE_CHUNK_SIZE=200
ALPACA_TIMEFRAME=1Min
ALPACA_BAR_LIMIT=60
ALPACA_MARKET_DATA_LOOKBACK_DAYS=5

# Universe filters
ALPACA_REQUIRE_TRADABLE=true
ALPACA_REQUIRE_ETB=true
ALPACA_SHORT_REQUIRE_SHORTABLE=true
ALPACA_SHORT_REQUIRE_ETB=true
ALPACA_ALLOWED_BORROW_STATUSES=easy_to_borrow,available
ALPACA_MAX_SPREAD_PCT=0.5
ALPACA_SPREAD_RULES=1:0.50,2:0.35,5:0.25,20:0.15
ALPACA_MAX_ABSOLUTE_SPREAD=0.10

# WebSocket scanner
ALPACA_USE_WEBSOCKET=false
ALPACA_USE_MARKET_DATA_STREAM=true
ALPACA_USE_TRADE_UPDATE_STREAM=true
ALPACA_ENABLE_STREAM_STRATEGY=false
ALPACA_MARKET_DATA_FEED=iex
ALPACA_WEBSOCKET_BROAD_BARS=true
ALPACA_MAX_CANDIDATE_SYMBOLS=100
ALPACA_MAX_HIGH_PRIORITY_SYMBOLS=20
ALPACA_CANDIDATE_TTL_SECONDS=900
ALPACA_CANDIDATE_RETENTION_SECONDS=900
ALPACA_TOP_GAINERS_COUNT=20
ALPACA_TOP_LOSERS_COUNT=20
ALPACA_CANDIDATE_ENTER_SCORE=70
ALPACA_CANDIDATE_EXIT_SCORE=50
ALPACA_CANDIDATE_MAX_AGE_SECONDS=300
ALPACA_MIN_5M_GAIN_PCT=8
ALPACA_MIN_15M_GAIN_PCT=15
ALPACA_MIN_RELATIVE_VOLUME=3
ALPACA_RVOL_LOOKBACK_DAYS=20
ALPACA_RVOL_MIN_MINUTES_AFTER_OPEN=5
ALPACA_MIN_INTRADAY_DOLLAR_VOLUME=500000
ALPACA_STALE_QUOTE_SECONDS=2
ALPACA_STALE_TRADE_SECONDS=3
ALPACA_STALE_BAR_SECONDS=90
ALPACA_MAX_EVENT_LOOP_LAG_MS=250
ALPACA_MAX_SLIPPAGE_PCT=0.2
ALPACA_ENTRY_ORDER_TIMEOUT_SECONDS=5
ALPACA_EXIT_ORDER_TIMEOUT_SECONDS=10
ALPACA_ENTRY_MAX_REPRICE_ATTEMPTS=2
ALPACA_EXIT_MAX_REPRICE_ATTEMPTS=3
ALPACA_REVALIDATE_SIGNAL_BEFORE_REPRICE=true
ALPACA_MAX_ENTRY_SLIPPAGE_PCT=0.15
ALPACA_MAX_EXIT_SLIPPAGE_PCT=0.30
ALPACA_MAX_OPEN_POSITIONS=3
ALPACA_MAX_DAILY_LOSS=30

# VWAP mean-reversion strategy
ALPACA_VWAP_ENTRY_DEVIATION_PCT=4.0
ALPACA_FIRST_ORDER_EQUITY_PCT=8.0
ALPACA_FIXED_ENTRY_NOTIONAL=240
ALPACA_ENABLE_SECOND_ENTRY=true
ALPACA_SECOND_ORDER_DISTANCE_PCT=4.0
ALPACA_SECOND_ORDER_EQUITY_PCT=8.0

# Risk
ALPACA_MAX_LOSS_PER_SYMBOL_EQUITY_PCT=1.0
ALPACA_REQUIRE_HARD_STOP=true
ALPACA_HARD_STOP_DISTANCE_PCT=6.0
ALPACA_ONE_TRADE_CYCLE_PER_SYMBOL_PER_DAY=true
ALPACA_MAX_ENTRIES_PER_CYCLE=2
ALPACA_MAX_NOTIONAL_PER_ORDER=500
ALPACA_MAX_GROSS_EXPOSURE_EQUITY_PCT=40
ALPACA_MAX_NET_LONG_EXPOSURE_EQUITY_PCT=25
ALPACA_MAX_NET_SHORT_EXPOSURE_EQUITY_PCT=25
ALPACA_MAX_DAILY_LOSS_EQUITY_PCT=1.5
ALPACA_MAX_DAILY_LOSS_ABSOLUTE=30
ALPACA_MIN_CASH_RESERVE=1000
ALPACA_MIN_BUYING_POWER_RESERVE=1000

# Circuit breakers
ALPACA_HALT_ON_STREAM_DISCONNECT=true
ALPACA_HALT_ON_TRADE_STREAM_DISCONNECT=true
ALPACA_HALT_ON_RECONCILIATION_FAILURE=true
ALPACA_HALT_ON_REPEATED_ORDER_REJECTION=true
ALPACA_MAX_ORDER_REJECTIONS_PER_DAY=3
ALPACA_MAX_CONSECUTIVE_API_ERRORS=5

# Session management
ALPACA_TIMEZONE=America/New_York
ALPACA_NO_NEW_ENTRIES_AFTER=15:30
ALPACA_FORCE_FLATTEN_TIME=15:55
ALPACA_FINAL_POSITION_CHECK_TIME=15:58
ALPACA_REGULAR_SESSION_ONLY=true
ALPACA_NO_OVERNIGHT=true

# Legacy manual order default; strategy sizing now uses equity percentage.
ALPACA_SHORT_SPIKE_NOTIONAL=500

ALPACA_DRY_RUN=true
ALPACA_ENABLE_TRADING=false

ALPACA_JOURNAL_PATH=/opt/alpaca-bot/logs/trade_journal.jsonl
ALPACA_SHADOW_JOURNAL_PATH=/opt/alpaca-bot/logs/shadow_journal.jsonl
ALPACA_MONITOR_INTERVAL_SECONDS=60
