ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

ALPACA_SYMBOLS=AAPL,MSFT,NVDA
ALPACA_DYNAMIC_UNIVERSE=false
ALPACA_UNIVERSE_MAX_SYMBOLS=100
ALPACA_TIMEFRAME=1Min
ALPACA_BAR_LIMIT=60
ALPACA_MARKET_DATA_LOOKBACK_DAYS=5

# Universe filters
ALPACA_MIN_PRICE=1
ALPACA_MIN_AVG_DAILY_VOLUME_30D=3000000
ALPACA_REQUIRE_ETB=true
ALPACA_MAX_SPREAD_PCT=0.5

# VWAP mean-reversion strategy
ALPACA_VWAP_ENTRY_DEVIATION_PCT=4.0
ALPACA_FIRST_ORDER_EQUITY_PCT=8.0
ALPACA_SECOND_ORDER_DISTANCE_PCT=4.0
ALPACA_SECOND_ORDER_EQUITY_PCT=8.0

# Risk
ALPACA_MAX_LOSS_PER_SYMBOL_EQUITY_PCT=1.0
ALPACA_ONE_TRADE_CYCLE_PER_SYMBOL_PER_DAY=true
ALPACA_MAX_ENTRIES_PER_CYCLE=2
ALPACA_MAX_NOTIONAL_PER_ORDER=0
ALPACA_MIN_CASH_RESERVE=1000

# Session management
ALPACA_NO_NEW_ENTRIES_AFTER=15:30
ALPACA_FORCE_FLATTEN_TIME=15:55
ALPACA_FINAL_POSITION_CHECK_TIME=15:58
ALPACA_REGULAR_SESSION_ONLY=true
ALPACA_NO_OVERNIGHT=true

# Legacy manual order default; strategy sizing now uses equity percentage.
ALPACA_SHORT_SPIKE_NOTIONAL=500

ALPACA_DRY_RUN=true
ALPACA_ENABLE_TRADING=false
ALPACA_ALLOW_LIVE_TRADING=false

ALPACA_JOURNAL_PATH=/opt/alpaca-bot/logs/trade_journal.jsonl
ALPACA_MONITOR_INTERVAL_SECONDS=60
